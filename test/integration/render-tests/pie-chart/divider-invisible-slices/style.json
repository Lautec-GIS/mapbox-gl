{
  "_comment": "Renders a 4-slice pie chart where slices 1 and 3 are invisible; dividers should still appear at all sector boundaries including those adjacent to invisible slices",
  "version": 8,
  "metadata": {
    "test": {
      "width": 64,
      "height": 64
    }
  },
  "sources": {
    "geojson": {
      "type": "geojson",
      "data": {
        "type": "FeatureCollection",
        "features": [
          {
            "type": "Feature",
            "properties": {
              "mask": 2.9802322387695312e-07
            },
            "geometry": {
              "type": "Point",
              "coordinates": [0, 0]
            }
          }
        ]
      }
    }
  },
  "layers": [
    {
      "id": "pie",
      "type": "pie-chart",
      "source": "geojson",
      "paint": {
        "pie-chart-mask": ["get", "mask"],
        "pie-chart-colors": ["red", "green", "blue", "yellow"],
        "pie-chart-size": 48,
        "pie-chart-stroke-color": "black",
        "pie-chart-divider-width": 0.05
      }
    }
  ]
}
